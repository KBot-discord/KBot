{
	"name": "kbot",
	"version": "3.0.0",
	"description": "A multi-feature Discord bot",
	"author": "@kbotdev",
	"license": "AGPL-3.0-or-later",
	"type": "module",
	"main": "./dist/KBot.js",
	"private": true,
	"repository": {
		"type": "git",
		"url": "https://github.com/KBot-discord/kbot.git"
	},
	"homepage": "https://github.com/KBot-discord/kbot",
	"scripts": {
		"build": "yarn check && tsdown",
		"check": "tsc",
		"dev": "tsdown --watch --onSuccess \"yarn start\"",
		"start": "node --enable-source-maps ./dist/KBot.js",
		"lint": "biome check --write .",
		"test": "vitest --watch=false",
		"test:watch": "vitest -w",
		"db:generate": "prisma generate",
		"db:push": "prisma db push",
		"db:migrate": "prisma migrate reset && prisma migrate dev",
		"docs:dev": "vitepress dev docs",
		"docs:build": "vitepress build docs",
		"docs:preview": "vitepress preview docs",
		"docker": "docker buildx build -t kbot/bot .",
		"dry-run": "yarn build && yarn lint && yarn test"
	},
	"dependencies": {
		"@kbotdev/plugin-modules": "^3.0.0",
		"@killbasa/redis-utils": "^0.0.10",
		"@prisma/client": "^6.19.3",
		"@sapphire/decorators": "^6.2.0",
		"@sapphire/discord.js-utilities": "^7.3.3",
		"@sapphire/duration": "^1.2.0",
		"@sapphire/fetch": "^3.0.5",
		"@sapphire/framework": "^5.5.0",
		"@sapphire/plugin-api": "^8.3.1",
		"@sapphire/plugin-logger": "^4.1.0",
		"@sapphire/plugin-scheduled-tasks": "^10.0.4",
		"@sapphire/utilities": "^3.18.2",
		"@sentry/integrations": "7.120.4",
		"@sentry/node": "^10.63.0",
		"@skyra/gifenc": "^1.0.1",
		"canvas": "3.2.3",
		"canvas-constructor": "^7.0.2",
		"colorette": "^2.0.20",
		"discord.js": "^14.26.4",
		"dotenv": "^17.4.2",
		"fuzzysort": "^3.1.0",
		"humanize-duration": "^3.34.0",
		"ioredis": "^5.11.1",
		"meilisearch": "^0.58.0",
		"prom-client": "^15.1.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.2",
		"@killbasa/prettier-config": "^1.0.2",
		"@killbasa/ts-config": "^1.0.0",
		"@sentry/types": "^10.63.0",
		"@swc/core": "^1.15.43",
		"@types/humanize-duration": "^3.27.4",
		"@types/node": "^26.1.0",
		"lint-staged": "^17.0.8",
		"prettier": "^3.9.4",
		"prisma": "^6.19.3",
		"tsdown": "^0.22.3",
		"tslib": "^2.8.1",
		"tsup": "^8.5.1",
		"typescript": "^6.0.3",
		"vitepress": "^1.6.4",
		"vitest": "^4.1.9"
	},
	"lint-staged": {
		"*.{mjs,cjs,js,ts}": [
			"biome check --write \"**/*.{mjs,cjs,js,ts}\""
		],
		"*.{json,yml,yaml}": [
			"biome format --write \"**/*.{json,yml,yaml}\""
		],
		"*.md": [
			"prettier --write --log-level=warn \"**/*.md\""
		]
	},
	"engines": {
		"node": "26.4.0"
	},
	"packageManager": "yarn@4.17.0",
	"volta": {
		"node": "26.4.0"
	}
}
